{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.3.9",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_extensionTitle__",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "identity",
    "identity.email",
    "offscreen"
  ],
  "oauth2": {
    "client_id": "1011595612073-ju1l7ofkdtmu4uinjdc8ubasvav4r3ff.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.appdata",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "host_permissions": [
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*",
    "https://www.twitch.tv/*",
    "https://gql.twitch.tv/*",
    "https://api.kick.com/*",
    "https://id.kick.com/*",
    "https://translate.googleapis.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://edge.microsoft.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://usher.ttvnw.net/*",
    "https://*.ttvnw.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["chatters-count.js", "auto-bonus.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["authorization-success.html", "authorization-success.js", "chatters-count.page.js", "irc-tap.page.js"],
      "matches": ["https://www.twitch.tv/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; media-src 'self' blob: https://usher.ttvnw.net https://*.ttvnw.net; connect-src 'self' https://api.twitch.tv https://id.twitch.tv https://gql.twitch.tv https://usher.ttvnw.net https://*.ttvnw.net https://api.kick.com https://id.kick.com https://translate.googleapis.com https://api-edge.cognitive.microsofttranslator.com https://edge.microsoft.com https://www.googleapis.com https://accounts.google.com; frame-ancestors 'none'; base-uri 'self';"
  }
}


